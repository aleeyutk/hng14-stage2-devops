# Redis configuration
# The hostname of the Redis service (use "redis" for Docker, "localhost" for local dev)
REDIS_HOST=redis

# Redis password - must match the password set in docker-compose redis command
REDIS_PASSWORD=changeme

# API URL used by the frontend to reach the API service
# Use "http://api:8000" inside Docker, "http://localhost:8000" for local dev
API_URL=http://api:8000

# Port the frontend will be exposed on the host machine
FRONTEND_PORT=3000
